# ============================================
# DATA PROVIDERS
# ============================================

# Twelve Data — forex candles 1h/4h/daily
# Get key: https://twelvedata.com/account/api-keys
TWELVEDATA_API_KEY=

# ============================================
# LLM PROVIDERS
# ============================================

# Anthropic Claude — used by Judge agent
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# DeepSeek — used by 4 strategy agents (cheaper, JSON mode native)
# Get key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Perplexity — used by Macro agent (web search)
# Get key: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Kimi (Moonshot AI) — long-context OpenAI-compatible model, optional agent alternative
# Get key: https://platform.moonshot.cn/console/api-keys
KIMI_API_KEY=

# ============================================
# CACHE / STORAGE
# ============================================

# Vercel KV (Upstash Redis under the hood)
# Auto-populated when you link KV in Vercel dashboard
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ============================================
# INNGEST (durable execution)
# ============================================

# Get keys: https://app.inngest.com/env/production/manage/keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ============================================
# OPTIONAL: Calendar / News
# ============================================

# Trading Economics free tier — 100 calls/day for calendar
TRADINGECONOMICS_API_KEY=

# ============================================
# SECURITY
# ============================================

# Primary frontend origin — MUST match your Vercel frontend URL.
# Default: https://xyc-fron.vercel.app
ALLOWED_ORIGIN=https://xyc-fron.vercel.app

# Extra allowed origins (comma-separated), e.g. for local dev:
# EXTRA_ORIGINS=http://localhost:3000,http://localhost:5173
EXTRA_ORIGINS=

# Shared secret for POST /api/council (Bearer token).
# Generate: openssl rand -hex 32
# Frontend must set VITE_INTERNAL_API_KEY to the same value.
INTERNAL_API_KEY=
